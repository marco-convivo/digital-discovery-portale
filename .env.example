# Supabase — progetto "Digital Discovery" (org dedicata, NON RevnaConsulting)
# Da Project Settings → API. La URL e la chiave pubblica sono esposte al browser.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# Solo server (webhook Fase 2): bypassa la RLS. MAI esporre al browser.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
